import pandas as pd
import requests
import os
from datetime import datetime

url = "https://api.worldbank.org/v2/country/USA/indicator/EN.ATM.CO2E.PC?format=json&per_page=20000"
response = requests.get(url)
raw_data = response.json()

print(f"Записей получено: {len(raw_data[1])}")

df = pd.json_normalize(raw_data[1])

print("--- Первые строки ДО очистки ---")
display(df.head(3))
print("\n--- Типы данных ДО очистки ---")
print(df.dtypes)
print(f"\nРазмер таблицы: {df.shape}")

df_clean = df[['date', 'value', 'countryiso3code', 'indicator.id']].copy()
df_clean.rename(columns={'date': 'year', 'indicator.id': 'indicator'}, inplace=True)

df_clean['year'] = df_clean['year'].astype(int)
df_clean['value'] = pd.to_numeric(df_clean['value'])

rows_before = len(df_clean)
df_clean = df_clean.dropna(subset=['value'])
rows_after = len(df_clean)

print(f"Удалено пустых строк: {rows_before - rows_after}")
print("\n--- Финальная таблица ---")
display(df_clean.head())
print("\n--- Финальные типы данных ---")
print(df_clean.dtypes)
